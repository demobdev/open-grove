{
  "name": "open-grove-app",
  "version": "0.1.0",
  "private": true,
  "main": "main/background.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "dev:desktop": "concurrently \"pnpm dev:frontend\" \"wait-on http://localhost:3000 && electron . --dev\"",
